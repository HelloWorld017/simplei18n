{
  "name": "simplei18n",
  "version": "0.0.3",
  "description": "Yet another simple, minimal i18n library",
  "license": "MIT",
  "author": "Khinenw",
  "repository": "https://github.com/HelloWorld017/simplei18n",
  "bin": {
    "simplei18n": "./dist/bin/cli.mjs"
  },
  "type": "module",
  "main": "./dist/src/index.mjs",
  "types": "./dist/src/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.mts",
      "default": "./dist/src/index.mjs"
    },
    "./react": {
      "types": "./dist/src/integrations/react.d.mts",
      "default": "./dist/src/integrations/react.mjs"
    },
    "./vite": {
      "types": "./dist/src/integrations/vite.d.mts",
      "default": "./dist/src/integrations/vite.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "jiti": "^2.4.2",
    "js-yaml": "^4.1.0",
    "oxc-parser": "0.135.0",
    "parjs": "^1.3.9",
    "sade": "^1.8.1",
    "valibot": "^1.4.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "@types/react": ">=19",
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
