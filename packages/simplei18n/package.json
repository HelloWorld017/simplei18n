{
  "name": "@simplei18n/core",
  "version": "0.1.0",
  "description": "Yet another simple, minimal i18n library",
  "license": "MIT",
  "author": "Khinenw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HelloWorld017/simplei18n.git"
  },
  "bin": {
    "simplei18n": "dist/cli.mjs"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "react-server": {
        "types": "./dist/react-server.d.mts",
        "default": "./dist/react-server.mjs"
      },
      "types": "./dist/react-client.d.mts",
      "default": "./dist/react-client.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "fast-glob": "^3.3.3",
    "jiti": "^2.4.2",
    "js-yaml": "^4.1.0",
    "oxc-parser": "0.135.0",
    "parjs": "^1.3.9",
    "sade": "^1.8.1",
    "valibot": "^1.4.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "@types/react": ">=19",
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
